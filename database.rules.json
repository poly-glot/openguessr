{
  "rules": {
    ".read": false,
    ".write": false,
    "games": {
      "$roomId": {
        ".read": "auth != null",
        "players": {
          "$uid": {
            "name": {
              ".write": "auth != null && auth.uid == $uid",
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 32"
            },
            "score": {
              ".write": false
            },
            "joinedAt": {
              ".write": "auth != null && auth.uid == $uid && !data.exists()",
              ".validate": "newData.isNumber()"
            },
            "guesses": {
              "$round": {
                ".write": "auth != null && auth.uid == $uid && !data.exists()",
                ".validate": "newData.hasChildren(['lat', 'lng', 'timestamp', 'score'])"
              }
            }
          }
        }
      }
    },
    "game-answers": {
      ".read": false,
      ".write": false
    },
    "promotionRequests": {
      "$roomId": {
        ".read": "auth != null",
        ".write": false
      }
    },
    "location-pool": {
      ".read": false,
      ".write": false
    }
  }
}
