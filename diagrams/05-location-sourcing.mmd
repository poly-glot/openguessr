flowchart TB
    Schedule["Daily scheduled function\n(every 24 hours UTC)"] --> PoolCheck{"Pool\n< 500?"}
    PoolCheck -->|"No"| Skip["Skip generation"]
    PoolCheck -->|"Yes"| Gemini["Vertex AI Gemini 2.5 Flash\nGenerate 50 coordinates"]
    Gemini --> Parse["Parse JSON response\nValidate lat/lng/country"]
    Parse --> Validate["Street View Metadata API\nCheck coverage (batches of 10)"]
    Validate --> Dedup["Deduplicate against pool\n(rounded to 2 decimal places)"]
    Dedup --> Pool["Location Pool\nRealtime Database"]

    Game["createGame called"] --> Read{"Pool has\n>= 5 entries?"}
