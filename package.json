{
  "name": "openguessr-firebase",
  "version": "1.0.0",
  "description": "GeoGuessr-style country guessing game with Firebase",
  "type": "module",
  "scripts": {
    "test": "firebase emulators:exec --project demo-openguessr --only auth,database,functions,hosting \"vitest run\"",
    "test:watch": "firebase emulators:exec --project demo-openguessr --only auth,database,functions,hosting \"vitest\"",
    "start": "firebase emulators:exec --project demo-openguessr \"vite --mode development\"",
    "serve": "firebase emulators:start --project demo-openguessr",
    "build": "vite build",
    "preview": "vite preview"
  },
  "license": "MIT",
  "dependencies": {
    "firebase": "^11.3.0",
    "leaflet": "^1.9.4",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@playwright/test": "^1.40.0",
    "@vitest/coverage-v8": "^3.2.4",
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^6.2.0",
    "firebase-functions-test": "^3.4.0",
    "jsdom": "^26.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
