# Production — real Firebase, restricted API key
#
# VITE_GOOGLE_MAPS_API_KEY is injected at build time from the
# GOOGLE_MAPS_API_KEY GitHub secret (see .github/workflows/ci.yml).
#
# To retrieve the secret locally from GCP Secret Manager:
#   gcloud secrets versions access latest \
#     --secret=openguessr-GOOGLE_MAPS_API_KEY \
#     --project=firebase-cloud-491613
#
VITE_USE_EMULATORS=false
VITE_GOOGLE_MAPS_API_KEY=REPLACE_AT_BUILD_TIME
